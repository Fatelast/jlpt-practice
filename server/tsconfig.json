{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "paths": {
      "@jlpt-practice/shared": [
        "../packages/shared/src"
      ]
    },
    "incremental": true,
    "strictPropertyInitialization": false
  },
  "include": [
    "src/**/*.ts",
    "prisma/**/*.ts"
  ]
}
